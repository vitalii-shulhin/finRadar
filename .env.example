# Financial Modeling Prep API Key
# Get your free API key at: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_api_key_here

# Optional: NewsAPI.org for additional news (100 requests/day free)
# Get key at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# App Configuration
NEXT_PUBLIC_APP_NAME=FinRadar
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SEO Configuration
# Site URL (used in sitemap, structured data, Open Graph)
# Production: https://finradar.com.ua
# Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Search Console Verification
# Get this from: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code_here

# Yandex Webmaster Verification (optional)
# Get this from: https://webmaster.yandex.com
